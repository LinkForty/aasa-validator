{
  "name": "@linkforty/aasa-node",
  "version": "0.2.0",
  "description": "Node/Express reference backend for AASA Validator.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/app.js",
  "types": "./dist/app.d.ts",
  "exports": {
    ".": {
      "types": "./dist/app.d.ts",
      "import": "./dist/app.js"
    }
  },
  "bin": {
    "aasa-validator-server": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "node --watch --experimental-strip-types src/index.ts",
    "start": "node dist/index.js",
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@linkforty/aasa-core": "workspace:*",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "supertest": "^7.0.0",
    "@types/supertest": "^6.0.2"
  }
}
